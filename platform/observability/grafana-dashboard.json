{
    "__inputs": [
        {
            "name": "DS_PROMETHEUS",
            "label": "Prometheus",
            "description": "",
            "type": "datasource",
            "pluginId": "prometheus",
            "pluginName": "Prometheus"
        }
    ],
    "__requires": [
        {
            "type": "grafana",
            "id": "grafana",
            "name": "Grafana",
            "version": "10.0.0"
        },
        {
            "type": "datasource",
            "id": "prometheus",
            "name": "Prometheus",
            "version": "1.0.0"
        },
        {
            "type": "panel",
            "id": "timeseries",
            "name": "Time series",
            "version": ""
        },
        {
            "type": "panel",
            "id": "stat",
            "name": "Stat",
            "version": ""
        },
        {
            "type": "panel",
            "id": "gauge",
            "name": "Gauge",
            "version": ""
        }
    ],
    "annotations": {
        "list": []
    },
    "description": "E-Commerce Platform — HTTP rates, error rates, latency (p50/p95/p99), pod memory/CPU, DB connections",
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 1,
    "id": null,
    "links": [],
    "panels": [
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 0
            },
            "id": 100,
            "title": "🌐 HTTP Traffic",
            "type": "row"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "lineWidth": 2
                    },
                    "unit": "reqps"
                },
                "overrides": []
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 1
            },
            "id": 1,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${DS_PROMETHEUS}"
                    },
                    "expr": "sum(rate(http_requests_total{namespace=\"ecommerce-dev\"}[5m])) by (service)",
                    "legendFormat": "{{service}}",
                    "refId": "A"
                }
            ],
            "title": "Request Rate by Service (req/s)",
            "type": "timeseries"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 0.01
                            },
                            {
                                "color": "red",
                                "value": 0.05
                            }
                        ]
                    },
                    "unit": "percentunit",
                    "max": 0.2
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 1
            },
            "id": 2,
            "options": {
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "${DS_PROMETHEUS}"
                    },
                    "expr": "sum(rate(http_requests_total{namespace=\"ecommerce-dev\", status_code=~\"5..\"}[5m])) by (service) / sum(rate(http_requests_total{namespace=\"ecommerce-dev\"}[5m])) by (service)",
                    "legendFormat": "{{service}}",
                    "refId": "A"
                }
            ],
            "title": "5xx Error Rate by Service",
            "type": "timeseries"
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 9
            },
            "id": 101,
            "title": "⏱ Latency (p50 / p95 / p99)",
            "type": "row"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "lineWidth": 2
                    },
                    "unit": "s"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 10
            },
            "id": 3,
            "options": {
                "legend": {
                    "displayMode": "table",
                    "placement": "right",
                    "calcs": [
                        "mean",
                        "max"
                    ]
                },
                "tooltip": {
                    "mode": "multi"
                }
            },
            "targets": [
                {
                    "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"ecommerce-dev\"}[5m])) by (le, service))",
                    "legendFormat": "p50 {{service}}",
                    "refId": "A"
                },
                {
                    "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"ecommerce-dev\"}[5m])) by (le, service))",
                    "legendFormat": "p95 {{service}}",
                    "refId": "B"
                },
                {
                    "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"ecommerce-dev\"}[5m])) by (le, service))",
                    "legendFormat": "p99 {{service}}",
                    "refId": "C"
                }
            ],
            "title": "Request Latency Percentiles",
            "type": "timeseries"
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 18
            },
            "id": 102,
            "title": "🖥 Pod Resources",
            "type": "row"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "lineWidth": 1
                    },
                    "unit": "bytes"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 19
            },
            "id": 4,
            "targets": [
                {
                    "expr": "sum(container_memory_working_set_bytes{namespace=\"ecommerce-dev\", container!=\"\"}) by (pod)",
                    "legendFormat": "{{pod}}",
                    "refId": "A"
                }
            ],
            "title": "Memory Usage by Pod",
            "type": "timeseries"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "lineWidth": 1
                    },
                    "unit": "short"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 19
            },
            "id": 5,
            "targets": [
                {
                    "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"ecommerce-dev\", container!=\"\"}[5m])) by (pod)",
                    "legendFormat": "{{pod}}",
                    "refId": "A"
                }
            ],
            "title": "CPU Usage by Pod (cores)",
            "type": "timeseries"
        },
        {
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 27
            },
            "id": 103,
            "title": "🗄 Database Health",
            "type": "row"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 10
                            },
                            {
                                "color": "red",
                                "value": 20
                            }
                        ]
                    },
                    "unit": "short"
                }
            },
            "gridPos": {
                "h": 6,
                "w": 8,
                "x": 0,
                "y": 28
            },
            "id": 6,
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background"
            },
            "targets": [
                {
                    "expr": "pg_stat_database_numbackends{namespace=\"ecommerce-dev\"}",
                    "legendFormat": "PG Active Connections",
                    "refId": "A"
                }
            ],
            "title": "PostgreSQL Active Connections",
            "type": "stat"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "red",
                                "value": 1
                            }
                        ]
                    },
                    "unit": "short"
                }
            },
            "gridPos": {
                "h": 6,
                "w": 8,
                "x": 8,
                "y": 28
            },
            "id": 7,
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ]
                },
                "orientation": "auto",
                "textMode": "auto",
                "colorMode": "background"
            },
            "targets": [
                {
                    "expr": "kube_pod_container_status_restarts_total{namespace=\"ecommerce-dev\", container=~\"mongodb|postgresql|redis\"}",
                    "legendFormat": "{{container}} restarts",
                    "refId": "A"
                }
            ],
            "title": "Database Pod Restarts",
            "type": "stat"
        },
        {
            "datasource": {
                "type": "prometheus",
                "uid": "${DS_PROMETHEUS}"
            },
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "unit": "short"
                }
            },
            "gridPos": {
                "h": 6,
                "w": 8,
                "x": 16,
                "y": 28
            },
            "id": 8,
            "targets": [
                {
                    "expr": "redis_connected_clients{namespace=\"ecommerce-dev\"}",
                    "legendFormat": "Redis Clients",
                    "refId": "A"
                }
            ],
            "title": "Redis Connected Clients",
            "type": "timeseries"
        }
    ],
    "refresh": "30s",
    "schemaVersion": 38,
    "tags": [
        "ecommerce",
        "microservices",
        "kubernetes"
    ],
    "templating": {
        "list": []
    },
    "time": {
        "from": "now-3h",
        "to": "now"
    },
    "timepicker": {},
    "timezone": "browser",
    "title": "E-Commerce Platform Overview",
    "uid": "ecommerce-overview",
    "version": 1
}