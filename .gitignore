# ── Secrets — never commit .env files ────────────────────────
.env
!.env.example

# ── Node.js ───────────────────────────────────────────────────
node_modules/
npm-debug.log*

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ── Rust ──────────────────────────────────────────────────────
target/

# ── Terraform ─────────────────────────────────────────────────
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
.terraform.lock.hcl

# ── Helm — downloaded sub-chart tarballs (regenerated by helm dependency update)
helm-charts/databases/charts/
helm-charts/databases/Chart.lock

# ── OS / IDE ──────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.log
