# frontend/.env.example
# Copy to .env for local development (outside k8s)
# These values are only used when running `npm run dev` directly.
# In k8s, the nginx config is baked into the Docker image at build time.

# URL of the api-gateway-bff (for development proxy)
VITE_API_BASE_URL=http://localhost:3001

# Environment (development | staging | production)
VITE_APP_ENV=development
